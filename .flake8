[flake8]
max-line-length = 127
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    .eggs,
    *.egg-info
# Style debt in legacy modules — enforce syntax/undefined-name errors in CI.
extend-ignore =
    E127,
    E128,
    E131,
    E265,
    E302,
    E303,
    E305,
    E402,
    E501,
    E722,
    W291,
    W293,
    F401,
    F541,
    F811,
    F841
per-file-ignores =
    core/unified_automl.py:E402
